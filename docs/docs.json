{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "typesync",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#357470",
    "light": "#48A77B",
    "dark": "#357470"
  },
  "background": {
    "color": {
      "dark": "#030a08"
    }
  },
  "logo": { "light": "images/logo-light.png", "dark": "images/logo-dark.png" },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/kafkas/typesync"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/kafkas/typesync"
        },
        {
          "anchor": "Changelog",
          "icon": "list-tree",
          "href": "https://github.com/kafkas/typesync/blob/main/CHANGELOG.md"
        },
        {
          "anchor": "Support",
          "icon": "discord",
          "href": "https://discord.gg/Hb2HW98DvF"
        }
      ]
    },
    "groups": [
      {
        "group": "Overview",
        "pages": ["introduction", "installation", "quickstart", "upgrading"]
      },
      {
        "group": "Schema",
        "pages": ["schema/definition", "schema/types"]
      },
      {
        "group": "CLI Reference",
        "pages": [
          "cli/generate-ts",
          "cli/generate-swift",
          "cli/generate-py",
          "cli/generate-rules",
          "cli/generate-graph",
          "cli/validate-data",
          "cli/validate"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/Hb2HW98DvF",
      "github": "https://github.com/kafkas/typesync"
    }
  }
}
