{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": false,
    "types": ["node", "yargs"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "client/**/*",
    "dist",
    "lib",
    "playground/**/*",
    "scripts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/__tests__/**/*",
    "tests/**/*",
    "tsup.config.ts",
    "vitest.config.ts",
    "vitest.security.config.ts"
  ]
}
